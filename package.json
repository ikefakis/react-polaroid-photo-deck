{
  "name": "@ikefakis/react-polaroid-photo-deck",
  "version": "3.0.4",
  "description": "A beautiful polaroid style photo deck",
  "keywords": [
    "react",
    "polaroid",
    "gallery",
    "photos"
  ],
  "homepage": "https://ikefakis.github.io/react-polaroid-photo-deck",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikefakis/react-polaroid-photo-deck.git"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "vite build --mode lib && tsc -p tsconfig.lib.json",
    "prepublishOnly": "npm run build:lib",
    "test": "node -e \"console.log('No tests configured')\""
  },
  "dependencies": {
    "@react-spring/web": "^10.0.3",
    "@use-gesture/react": "^10.3.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@react-spring/web": "^10.0.3",
    "@use-gesture/react": "^10.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.5",
    "typescript": "^5.8.2",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.6",
    "react": "^18.1.0",
    "react-dom": "^18.1.0"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
